# Environment files
.env
.env.*
!.env.sample

# Generated configuration files
/config/*
!/config/.gitkeep

# Runtime data
/data/*
!/data/.gitkeep

# Backup files
/backup/*
!/backup/.gitkeep

# Logs and temporary files
*.log
logs/
*/logs/
*.tmp
*.bak
*.orig
*.swp
*~
.DS_Store

# Database data
data/db/
data/mariadb/
*.ibd
*.frm
*.MYD
*.MYI
*.pid
*.sock

# Secrets and keys
*secret*
*password*
*.key
*.pem
