# =========================================================
# PowerDNS Stack Environment Sample
# Copy this file to .env and edit values.
# DO NOT commit .env to Git.
# =========================================================

MODULE_PREFIX=pdnsstack
BASE_DIR=/srv/pdns-stack
QUADLET_DIR=/etc/containers/systemd
SYSTEMD_DIR=/etc/systemd/system

HOST_IPV4=192.168.0.2
LAN_ALLOWED_CIDR=192.168.0.0/24
ZABBIX_SERVER_IPV4=192.168.0.5
DB_ALLOWED_CIDR=192.168.0.0/24
ADMIN_ALLOWED_CIDR=192.168.0.0/24

# Podman network
PDNS_NETWORK_NAME=pdnsstack-net
PDNS_IPV4_SUBNET=172.30.0.0/24
PDNS_IPV4_GATEWAY=172.30.0.254
PDNS_IPV6_SUBNET=fd00:53::/64

# Container names
DNSDIST_CONTAINER=pdnsstack-dnsdist
CACHE_INT_CONTAINER=pdnsstack-cache-int
CACHE_NGN_CONTAINER=pdnsstack-cache-ngn
PDNS_AUTH_CONTAINER=pdnsstack-auth
DB_CONTAINER=pdnsstack-db
POWERADMIN_CONTAINER=pdnsstack-poweradmin
BACKUP_CONTAINER=pdnsstack-backup

# Container IPv4 addresses
DNSDIST_IPV4=172.30.0.10
CACHE_INT_IPV4=172.30.0.11
CACHE_NGN_IPV4=172.30.0.12
PDNS_AUTH_IPV4=172.30.0.13
DB_IPV4=172.30.0.14
POWERADMIN_IPV4=172.30.0.15

# Container IPv6 addresses
DNSDIST_IPV6=fd00:53::10
CACHE_INT_IPV6=fd00:53::11
CACHE_NGN_IPV6=fd00:53::12
PDNS_AUTH_IPV6=fd00:53::13
DB_IPV6=fd00:53::14
POWERADMIN_IPV6=fd00:53::15

# Host exposed ports
DNSDIST_DNS_PORT=53
DB_PORT=3306

CACHE_INT_DNS_PORT=10053
CACHE_INT_API_PORT=10080

CACHE_NGN_DNS_PORT=10054
CACHE_NGN_API_PORT=10081

PDNS_AUTH_DNS_PORT=11053
PDNS_AUTH_API_PORT=11080

POWERADMIN_PORT=12080

# Container internal service ports
CACHE_INT_INTERNAL_DNS_PORT=5300
CACHE_INT_INTERNAL_API_PORT=8082
CACHE_NGN_INTERNAL_DNS_PORT=5300
CACHE_NGN_INTERNAL_API_PORT=8084
PDNS_AUTH_INTERNAL_DNS_PORT=5300
PDNS_AUTH_INTERNAL_API_PORT=8081
POWERADMIN_CONTAINER_PORT=80

# MariaDB root
MYSQL_ROOT_PASSWORD=change-this-root-password

# Database for PowerDNS Authoritative
PDNS_AUTH_DB_NAME=powerdns
PDNS_AUTH_DB_USER=powerdns
PDNS_AUTH_DB_PASSWORD=change-this-pdns-auth-db-password

# Database for PowerAdmin. Normally same as PDNS_AUTH_DB_*.
POWERADMIN_DB_NAME=powerdns
POWERADMIN_DB_USER=powerdns
POWERADMIN_DB_PASSWORD=change-this-poweradmin-db-password

# PowerDNS API keys
PDNS_AUTH_API_KEY=change-this-pdns-auth-api-key
CACHE_INT_API_KEY=change-this-cache-int-api-key
CACHE_NGN_API_KEY=change-this-cache-ngn-api-key

# dnsdist API / Console
DNSDIST_API_KEY=change-this-dnsdist-api-key
DNSDIST_CONSOLE_KEY=change-this-dnsdist-console-key

# PowerAdmin
POWERADMIN_ADMIN_USER=admin
POWERADMIN_ADMIN_PASSWORD=change-this-poweradmin-password
POWERADMIN_SESSION_KEY=change-this-random-session-key

# Normal Internet upstream DNS. Leave empty to use cache-int as full resolver.
UPSTREAM_DNS_IPV4_1=1.1.1.1
UPSTREAM_DNS_IPV4_2=9.9.9.9
UPSTREAM_DNS_IPV6_1=
UPSTREAM_DNS_IPV6_2=

# NGN IPv6 DNS. If both are empty, pdnsstack-cache-ngn is disabled.
NGN_DNS_IPV6_1=
NGN_DNS_IPV6_2=

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="Sun *-*-* 03:00:00"
