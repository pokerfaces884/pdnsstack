# =========================================================
# PowerDNS Stack Environment Sample
# Copy this file to .env and edit values.
# DO NOT commit .env to Git.
# =========================================================

# ---------------------------------------------------------
# Basic Settings
# ---------------------------------------------------------

PDNSSTACK_MODULE_PREFIX=pdnsstack

PDNSSTACK_BASE_DIR=/opt/pdnsstack
PDNSSTACK_QUADLET_DIR=/etc/containers/systemd
PDNSSTACK_SYSTEMD_DIR=/etc/systemd/system

PDNSSTACK_HOST_IPV4=192.168.0.2
PDNSSTACK_INITIAL_DOMAIN=example.com

PDNSSTACK_LAN_ALLOWED_CIDR=192.168.0.0/24
PDNSSTACK_DB_ALLOWED_CIDR=192.168.0.0/24
PDNSSTACK_ADMIN_ALLOWED_CIDR=192.168.0.0/24

PDNSSTACK_ZABBIX_SERVER_IPV4=192.168.0.5

# ---------------------------------------------------------
# Host Exposed Ports
# ---------------------------------------------------------

# please set to 53, if you want to work privileges with rootfull.
PDNSSTACK_DNSDIST_DNS_PORT=1053
PDNSSTACK_DB_PORT=3306
PDNSSTACK_CACHE_INT_DNS_PORT=10053
PDNSSTACK_CACHE_INT_API_PORT=10080
PDNSSTACK_CACHE_NGN_DNS_PORT=10054
PDNSSTACK_CACHE_NGN_API_PORT=10081
PDNSSTACK_AUTH_DNS_PORT=11053
PDNSSTACK_AUTH_API_PORT=11080
PDNSSTACK_POWERADMIN_PORT=12080

# ---------------------------------------------------------
# Database
# ---------------------------------------------------------

PDNSSTACK_DB_ROOT_PASSWORD=change-this-root-password

PDNSSTACK_AUTH_DB_NAME=powerdns
PDNSSTACK_AUTH_DB_USER=powerdns
PDNSSTACK_AUTH_DB_PASSWORD=change-this-pdns-auth-db-password

PDNSSTACK_POWERADMIN_DB_NAME=powerdns
PDNSSTACK_POWERADMIN_DB_USER=powerdns
PDNSSTACK_POWERADMIN_DB_PASSWORD=change-this-poweradmin-db-password

# ---------------------------------------------------------
# PowerDNS / dnsdist API Keys
# Leave empty for auto generation by 01-create.sh
# ---------------------------------------------------------
PDNSSTACK_AUTH_API_KEY=
PDNSSTACK_RECURSOR_API_KEY=
PDNSSTACK_DNSDIST_API_KEY=
PDNSSTACK_DNSDIST_CONSOLE_KEY=
PDNSSTACK_DNSDIST_WEB_PASSWORD=

# ---------------------------------------------------------
# PowerAdmin
# ---------------------------------------------------------
PDNSSTACK_POWERADMIN_ADMIN_USER=admin
PDNSSTACK_POWERADMIN_ADMIN_PASSWORD=change-this-poweradmin-password
PDNSSTACK_POWERADMIN_SESSION_KEY=change-this-random-session-key

# ---------------------------------------------------------
# Upstream DNS
#    Default: 1 / Google Public DNS
#             2 / Cloudflare
# ---------------------------------------------------------
PDNSSTACK_UPSTREAM_DNS_IPV4_1=8.8.8.8
PDNSSTACK_UPSTREAM_DNS_IPV4_2=1.1.1.1

PDNSSTACK_UPSTREAM_DNS_IPV6_1=2001:4860:4860::8888
PDNSSTACK_UPSTREAM_DNS_IPV6_2=2606:4700:4700::1111

# ---------------------------------------------------------
# NGN DNS
# Leave empty to disable NGN cache
# ---------------------------------------------------------
PDNSSTACK_NGN_DNS_IPV6_1=
PDNSSTACK_NGN_DNS_IPV6_2=

# ---------------------------------------------------------
# Backup
# ---------------------------------------------------------
PDNSSTACK_BACKUP_RETENTION_DAYS=14

# --------------------------- DO NOT CHANGE PARAMETER BELOwS

# ---------------------------------------------------------
# Container IPv4
# ---------------------------------------------------------

PDNSSTACK_NETWORK_NAME=pdnsstack-net
PDNSSTACK_IPV4_SUBNET=172.30.0.0/24
PDNSSTACK_IPV4_GATEWAY=172.30.0.254
PDNSSTACK_DNSDIST_IPV4=172.30.0.10
PDNSSTACK_CACHE_INT_IPV4=172.30.0.11
PDNSSTACK_CACHE_NGN_IPV4=172.30.0.12
PDNSSTACK_AUTH_IPV4=172.30.0.13
PDNSSTACK_DB_IPV4=172.30.0.14
PDNSSTACK_POWERADMIN_IPV4=172.30.0.15

# ---------------------------------------------------------
# Container IPv6
# ---------------------------------------------------------

PDNSSTACK_IPV6_SUBNET=fd00:53::/64
PDNSSTACK_DNSDIST_IPV6=fd00:53::10
PDNSSTACK_CACHE_INT_IPV6=fd00:53::11
PDNSSTACK_CACHE_NGN_IPV6=fd00:53::12
PDNSSTACK_AUTH_IPV6=fd00:53::13
PDNSSTACK_DB_IPV6=fd00:53::14
PDNSSTACK_POWERADMIN_IPV6=fd00:53::15

# ---------------------------------------------------------
# Container Names
# ---------------------------------------------------------

PDNSSTACK_DNSDIST_NAME=pdnsstack-dnsdist
PDNSSTACK_CACHE_INT_NAME=pdnsstack-cache-int
PDNSSTACK_CACHE_NGN_NAME=pdnsstack-cache-ngn
PDNSSTACK_AUTH_NAME=pdnsstack-auth
PDNSSTACK_DB_NAME=pdnsstack-db
PDNSSTACK_POWERADMIN_NAME=pdnsstack-poweradmin
PDNSSTACK_BACKUP_NAME=pdnsstack-backup

# ---------------------------------------------------------
# Internal Container Ports
# ---------------------------------------------------------
PDNSSTACK_CACHE_INT_INTERNAL_DNS_PORT=5300
PDNSSTACK_CACHE_INT_INTERNAL_API_PORT=8082
PDNSSTACK_CACHE_NGN_INTERNAL_DNS_PORT=5300
PDNSSTACK_CACHE_NGN_INTERNAL_API_PORT=8084
PDNSSTACK_AUTH_INTERNAL_DNS_PORT=5300
PDNSSTACK_AUTH_INTERNAL_API_PORT=8081
PDNSSTACK_POWERADMIN_CONTAINER_PORT=80

