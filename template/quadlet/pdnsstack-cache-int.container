[Unit]
Description=PowerDNS Stack Internal Cache Recursor
After=pdnsstack-net-network.service
Requires=pdnsstack-net-network.service

[Container]
ContainerName=${PDNSSTACK_CACHE_INT_NAME}
Image=docker.io/powerdns/pdns-recursor:latest
Network=pdnsstack-net.network
IP=${PDNSSTACK_CACHE_INT_IPV4}
IP6=${PDNSSTACK_CACHE_INT_IPV6}
Volume=${PDNSSTACK_BASE_DIR}/config/cache-int/recursor.yml:/etc/powerdns/recursor.yml:ro,Z
PublishPort=${PDNSSTACK_HOST_IPV4}:${PDNSSTACK_CACHE_INT_DNS_PORT}:${PDNSSTACK_CACHE_INT_INTERNAL_DNS_PORT}/udp
PublishPort=${PDNSSTACK_HOST_IPV4}:${PDNSSTACK_CACHE_INT_DNS_PORT}:${PDNSSTACK_CACHE_INT_INTERNAL_DNS_PORT}/tcp
PublishPort=${PDNSSTACK_HOST_IPV4}:${PDNSSTACK_CACHE_INT_API_PORT}:${PDNSSTACK_CACHE_INT_INTERNAL_API_PORT}/tcp
Exec=pdns_recursor --config-dir=/etc/powerdns --yaml=recursor.yml

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
