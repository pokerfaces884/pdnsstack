launch=gmysql
gmysql-host=${PDNSSTACK_DB_IPV4}
gmysql-port=3306
gmysql-dbname=${PDNSSTACK_AUTH_DB_NAME}
gmysql-user=${PDNSSTACK_AUTH_DB_USER}
gmysql-password=${PDNSSTACK_AUTH_DB_PASSWORD}

local-address=0.0.0.0
local-port=${PDNSSTACK_AUTH_INTERNAL_DNS_PORT}

webserver=yes
webserver-address=0.0.0.0
webserver-port=${PDNSSTACK_AUTH_INTERNAL_API_PORT}
webserver-allow-from=0.0.0.0/0,::/0

api=yes
api-key=${PDNSSTACK_AUTH_API_KEY}
loglevel=4
